{
  "expo": {
    "name": "꽃시장",
    "slug": "flower-market",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.flowermarket.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.flowermarket.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "꽃 사진 등록을 위해 사진 라이브러리 접근 권한이 필요합니다.",
          "cameraPermission": "꽃 사진 촬영을 위해 카메라 접근 권한이 필요합니다."
        }
      ],
      "expo-secure-store",
      "expo-font"
    ],
    "platforms": [
      "ios",
      "android",
      "web"
    ],
    "scheme": "flowermarket",
    "extra": {
      "supabaseUrl": "",
      "supabaseAnonKey": ""
    }
  }
}
